ld is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:39:18.658858Z", "completed_at": "2026-07-19T10:39:18.668712Z"}, {"name": "execute", "started_at": "2026-07-19T10:39:18.671098Z", "completed_at": "2026-07-19T10:39:18.671107Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.022889375686645508, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.unique_stg_returns_return_id.c2232dee8a", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    return_id as unique_field,\n    count(*) as n_records\n\nfrom softcart_db.staging.stg_returns\nwhere return_id is not null\ngroup by return_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:39:18.651545Z", "completed_at": "2026-07-19T10:39:18.669832Z"}, {"name": "execute", "started_at": "2026-07-19T10:39:18.672473Z", "completed_at": "2026-07-19T10:39:18.672481Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.0318148136138916, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.unique_stg_customers_customer_id.c7614daada", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    customer_id as unique_field,\n    count(*) as n_records\n\nfrom softcart_db.staging.stg_customers\nwhere customer_id is not null\ngroup by customer_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:39:18.675497Z", "completed_at": "2026-07-19T10:39:18.682461Z"}, {"name": "execute", "started_at": "2026-07-19T10:39:18.687994Z", "completed_at": "2026-07-19T10:39:18.688006Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.017714977264404297, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_customer_cohorts", "compiled": true, "compiled_code": "\n\nwith customer_first_order as (\n    select\n        customer_id,\n        date_trunc('month', min(order_date)) as cohort_month\n    from softcart_db.marts.fct_orders\n    group by customer_id\n),\n\ncustomer_orders_with_cohort as (\n    select\n        fo.customer_id,\n        fo.order_id,\n        fo.order_date,\n        fco.cohort_month,\n        datediff('month', fco.cohort_month, date_trunc('month', fo.order_date)) as month_number\n    from softcart_db.marts.fct_orders fo\n    left join customer_first_order fco\n        on fo.customer_id = fco.customer_id\n)\n\nselect\n    cohort_month,\n    month_number,\n    count(distinct customer_id) as active_customers,\n    count(distinct order_id) as total_orders\nfrom customer_orders_with_cohort\ngroup by cohort_month, month_number\norder by cohort_month, month_number", "relation_name": "softcart_db.marts.fct_customer_cohorts", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:39:18.678904Z", "completed_at": "2026-07-19T10:39:18.683631Z"}, {"name": "execute", "started_at": "2026-07-19T10:39:18.696202Z", "completed_at": "2026-07-19T10:39:18.696212Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.024407625198364258, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_customer_rfm", "compiled": true, "compiled_code": "\n\nwith customer_orders as (\n    select\n        customer_id,\n        max(order_date) as last_order_date,\n        count(distinct order_id) as frequency,\n        sum(order_total) as monetary\n    from softcart_db.marts.fct_orders\n    group by customer_id\n),\n\nrfm_scores as (\n    select\n        customer_id,\n        last_order_date,\n        frequency,\n        monetary,\n        datediff('day', last_order_date, current_date()) as recency_days,\n\n        -- Score 1-5 for each dimension using quintiles (5 = best)\n        ntile(5) over (order by datediff('day', last_order_date, current_date()) desc) as recency_score,\n        ntile(5) over (order by frequency asc) as frequency_score,\n        ntile(5) over (order by monetary asc) as monetary_score\n    from customer_orders\n)\n\nselect\n    customer_id,\n    last_order_date,\n    recency_days,\n    frequency,\n    monetary,\n    recency_score,\n    frequency_score,\n    monetary_score,\n    (recency_score + frequency_score + monetary_score) as rfm_total_score,\n    case\n        when recency_score >= 4 and frequency_score >= 4 and monetary_score >= 4 then 'Champions'\n        when recency_score >= 3 and frequency_score >= 3 then 'Loyal Customers'\n        when recency_score >= 4 and frequency_score <= 2 then 'New Customers'\n        when recency_score <= 2 and frequency_score >= 3 then 'At Risk'\n        when recency_score <= 2 and frequency_score <= 2 and monetary_score <= 2 then 'Lost'\n        else 'Needs Attention'\n    end as customer_segment\nfrom rfm_scores\norder by rfm_total_score desc", "relation_name": "softcart_db.marts.fct_customer_rfm", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:39:18.684157Z", "completed_at": "2026-07-19T10:39:18.698135Z"}, {"name": "execute", "started_at": "2026-07-19T10:39:18.700589Z", "completed_at": "2026-07-19T10:39:18.700598Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.022556543350219727, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_returns_analysis", "compiled": true, "compiled_code": "\n\nwith product_sales as (\n    select\n        product_id,\n        sum(line_total) as total_sales,\n        count(distinct order_id) as total_orders_with_product\n    from softcart_db.marts.fct_orders\n    group by product_id\n),\n\nproduct_returns as (\n    select\n        oi.product_id,\n        count(distinct r.return_id) as total_returns,\n        sum(r.refund_amount) as total_refunded\n    from softcart_db.staging.stg_returns r\n    left join softcart_db.staging.stg_order_items oi\n        on r.order_id = oi.order_id\n    group by oi.product_id\n)\n\nselect\n    s.product_id,\n    p.product_name,\n    s.total_sales,\n    s.total_orders_with_product,\n    coalesce(r.total_returns, 0) as total_returns,\n    coalesce(r.total_refunded, 0) as total_refunded,\n    s.total_sales - coalesce(r.total_refunded, 0) as net_revenue,\n    round(\n        coalesce(r.total_returns, 0) / nullif(s.total_orders_with_product, 0) * 100,\n        2\n    ) as return_rate_pct\nfrom product_sales s\nleft join product_returns r\n    on s.product_id = r.product_id\nleft join softcart_db.staging.stg_products p\n    on s.product_id = p.product_id\norder by return_rate_pct desc", "relation_name": "softcart_db.marts.fct_returns_analysis", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:39:18.689023Z", "completed_at": "2026-07-19T10:39:18.700066Z"}, {"name": "execute", "started_at": "2026-07-19T10:39:18.702528Z", "completed_at": "2026-07-19T10:39:18.702536Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.021570444107055664, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_fct_returns_return_id.f5e79b5df0", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect return_id\nfrom softcart_db.marts.fct_returns\nwhere return_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:39:18.704544Z", "completed_at": "2026-07-19T10:39:18.738269Z"}, {"name": "execute", "started_at": "2026-07-19T10:39:18.738867Z", "completed_at": "2026-07-19T10:39:18.738878Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.0396273136