tg_returns r\nleft join softcart_db.staging.stg_orders o\n    on r.order_id = o.order_id\nwhere r.refund_amount > o.order_total", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:37:43.536425Z", "completed_at": "2026-07-19T10:37:43.553862Z"}, {"name": "execute", "started_at": "2026-07-19T10:37:43.554253Z", "completed_at": "2026-07-19T10:37:43.554260Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.018536090850830078, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_stg_returns_return_id.8e8e7cd8be", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect return_id\nfrom softcart_db.staging.stg_returns\nwhere return_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:37:43.520799Z", "completed_at": "2026-07-19T10:37:43.557256Z"}, {"name": "execute", "started_at": "2026-07-19T10:37:43.557585Z", "completed_at": "2026-07-19T10:37:43.557592Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.03983759880065918, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_returns", "compiled": true, "compiled_code": "\n\nselect\n    r.return_id,\n    r.order_id,\n    o.customer_id,\n    oi.product_id,\n    r.return_date,\n    r.reason,\n    r.status,\n    r.refund_amount\nfrom softcart_db.staging.stg_returns r\nleft join softcart_db.staging.stg_orders o\n    on r.order_id = o.order_id\nleft join softcart_db.staging.stg_order_items oi\n    on r.order_id = oi.order_id\nqualify row_number() over (partition by r.return_id order by oi.product_id) = 1", "relation_name": "softcart_db.marts.fct_returns", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:37:43.555623Z", "completed_at": "2026-07-19T10:37:43.563982Z"}, {"name": "execute", "started_at": "2026-07-19T10:37:43.564891Z", "completed_at": "2026-07-19T10:37:43.564900Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.009949684143066406, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_customer_cohorts", "compiled": true, "compiled_code": "\n\nwith customer_first_order as (\n    select\n        customer_id,\n        date_trunc('month', min(order_date)) as cohort_month\n    from softcart_db.marts.fct_orders\n    group by customer_id\n),\n\ncustomer_orders_with_cohort as (\n    select\n        fo.customer_id,\n        fo.order_id,\n        fo.order_date,\n        fco.cohort_month,\n        datediff('month', fco.cohort_month, date_trunc('month', fo.order_date)) as month_number\n    from softcart_db.marts.fct_orders fo\n    left join customer_first_order fco\n        on fo.customer_id = fco.customer_id\n)\n\nselect\n    cohort_month,\n    month_number,\n    count(distinct customer_id) as active_customers,\n    count(distinct order_id) as total_orders\nfrom customer_orders_with_cohort\ngroup by cohort_month, month_number\norder by cohort_month, month_number", "relation_name": "softcart_db.marts.fct_customer_cohorts", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:37:43.549227Z", "completed_at": "2026-07-19T10:37:43.564341Z"}, {"name": "execute", "started_at": "2026-07-19T10:37:43.565584Z", "completed_at": "2026-07-19T10:37:43.565593Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.017045259475708008, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.unique_stg_returns_return_id.c2232dee8a", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    return_id as unique_field,\n    count(*) as n_records\n\nfrom softcart_db.staging.stg_returns\nwhere return_id is not null\ngroup by return_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:37:43.542798Z", "completed_at": "2026-07-19T10:37:43.566115Z"}, {"name": "execute", "started_at": "2026-07-19T10:37:43.567516Z", "completed_at": "2026-07-19T10:37:43.567524Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.025383710861206055, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.relationships_stg_returns_order_id__order_id__ref_stg_orders_.c3a878ae38", "compiled": true, "compiled_code": "\n    \n    \n\nwith child as (\n    select order_id as from_field\n    from softcart_db.staging.stg_returns\n    where order_id is not null\n),\n\nparent as (\n    select order_id as to_field\n    from softcart_db.staging.stg_orders\n)\n\nselect\n    from_field\n\nfrom child\nleft join parent\n    on child.from_field = parent.to_field\n\nwhere parent.to_field is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:37:43.558953Z", "completed_at": "2026-07-19T10:37:43.566806Z"}, {"name": "execute", "started_at": "2026-07-19T10:37:43.568444Z", "completed_at": "2026-07-19T10:37:43.568452Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.010159015655517578, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_customer_rfm", "compiled": true, "compiled_code": "\n\nwith customer_orders as (\n    select\n        customer_id,\n        max(order_date) as last_order_date,\n        count(distinct order_id) as frequency,\n        sum(order_total) as monetary\n    from softcart_db.marts.fct_orders\n    group by customer_id\n),\n\nrfm_scores as (\n    select\n        customer_id,\n        last_order_date,\n        frequency,\n        monetary,\n        datediff('day', last_order_date, current_date()) as recency_days,\n\n        -- Score 1-5 for each dimension using quintiles (5 = best)\n        ntile(5) over (order by datediff('day', last_order_date, current_date()) desc) as recency_score,\n        ntile(5) over (order by frequency asc) as frequency_score,\n        ntile(5) over (order by monetary asc) as monetary_score\n    from customer_orders\n)\n\nselect\n    customer_id,\n    last_order_date,\n    recency_days,\n    frequency,\n    monetary,\n    recency_score,\n    frequency_score,\n    monetary_score,\n    (recency_score + frequency_score + monetary_score) as rfm_total_score,\n    case\n        when recency_score >= 4 and frequency_score >= 4 and monetary_score >= 4 then 'Champions'\n        when recency_score >= 3 and frequency_score >= 3 then 'Loyal Customers'\n        when recency_score >= 4 and frequency_score <= 2 then 'New Customers'\n        when recency_score <= 2 and frequency_score >= 3 then 'At Risk'\n        when recency_score <= 2 and frequency_score <= 2 and monetary_score <= 2 then 'Lost'\n        else 'Needs Attention'\n    end as customer_segment\nfrom rfm_scores\norder by rfm_total_score desc", "relation_name": "softcart_db.marts.fct_customer_rfm", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:37:43.571073Z", "completed_at": "2026-07-19T10:37:43.579028Z"}, {"name": "execute", "started_at": "2026-07-19T10:37:43.595214Z", "completed_at": "2026-07-19T10:37:43.595222Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.027265548706054688, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_returns_analysis", "compiled": true, "compiled_code": "\n\nwith product_sales as (\n    select\n        product_id,\n        sum(line_total) as total_sales,\n        count(distinct order_id) as total_orders_with_product\n    from softcart_db.marts.fct_orders\n    group by product_id\n),\n\nproduct_returns as (\n    select\n        oi.product_id,\n        count(distinct r.return_id) as total_returns,\n        sum(r.refund_amount) as total_refunded\n    from softcart_db.staging.stg_returns r\n    left join softcart_db.staging.stg_order_items oi\n        on r.order_id = oi.order_id\n    group by oi.product_id\n)\n\nselect\n    s.product_id,\n    p.product_name,\n    s.total_sales,\n    s.total_orders_with_product,\n    coalesce(r.total_returns, 0) as total_returns,\n    coalesce(r.total_refunded, 0) as total_refunded,\n    s.total_sales - coalesce(r.total_refunded, 0) as net_revenue,\n    round(\n        coalesce(r.total_returns, 0) / nullif(s.total_orders_with_product, 0) * 100,\n        2\n    ) as return_rate_pct\nfrom product_sales s\nleft join product_returns r\n    on s.product_id = r.product_id\nleft join softcart_db.staging.stg_products p\n    on s.product_id = p.product_id\norder by return_rate_pct desc", "relation_name": "softcart_db.marts.fct_returns_analysis", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:37:43.573485Z", "completed_at": "2026-07-19T10:37:43.592252Z"}, {"name": "execute", "started_at": "2026-07-19T10:37:43.595787Z", "completed_at": "2026-07-19T10:37:43.595794Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.026964664459228516, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_fct_returns_return_id.f5e79b5df0", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect return_id\nfrom softcart_db.marts.fct_returns\nwhere return_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-19T10:37:43.579392Z", "completed_at": "2026-07-19T10:37:43.597053Z"}, {"name": "execute", "started_at": "2026-07-19T10:37:43.598149Z", "completed_at": "2026-07-19T10:37:43.598168Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.02753