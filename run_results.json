": true, "compiled_code": "-- This test fails if any return's refund_amount exceeds the original order's order_total.\n-- A refund larger than the order itself is a data quality issue that should never happen.\n\nselect\n    r.return_id,\n    r.order_id,\n    r.refund_amount,\n    o.order_total\nfrom softcart_db.staging.stg_returns r\nleft join softcart_db.staging.stg_orders o\n    on r.order_id = o.order_id\nwhere r.refund_amount > o.order_total", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:35:26.706752Z", "completed_at": "2026-07-18T16:35:26.724957Z"}, {"name": "execute", "started_at": "2026-07-18T16:35:26.730971Z", "completed_at": "2026-07-18T16:35:26.730978Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.029026508331298828, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_stg_returns_order_id.d16a4eb67e", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect order_id\nfrom softcart_db.staging.stg_returns\nwhere order_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:35:26.711905Z", "completed_at": "2026-07-18T16:35:26.731574Z"}, {"name": "execute", "started_at": "2026-07-18T16:35:26.733395Z", "completed_at": "2026-07-18T16:35:26.733403Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.02931356430053711, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_stg_returns_return_id.8e8e7cd8be", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect return_id\nfrom softcart_db.staging.stg_returns\nwhere return_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:35:26.719789Z", "completed_at": 