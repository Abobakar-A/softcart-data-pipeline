ield is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:11:32.464331Z", "completed_at": "2026-07-18T16:11:32.477929Z"}, {"name": "execute", "started_at": "2026-07-18T16:11:32.484849Z", "completed_at": "2026-07-18T16:11:32.484859Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.021819591522216797, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.unique_stg_products_product_id.7d950a1467", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    product_id as unique_field,\n    count(*) as n_records\n\nfrom softcart_db.staging.stg_products\nwhere product_id is not null\ngroup by product_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:11:32.479687Z", "completed_at": "2026-07-18T16:11:32.490581Z"}, {"name": "execute", "started_at": "2026-07-18T16:11:32.497139Z", "completed_at": "2026-07-18T16:11:32.497150Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.022360563278198242, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.unique_stg_returns_return_id.c2232dee8a", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    return_id as unique_field,\n    count(*) as n_records\n\nfrom softcart_db.staging.stg_returns\nwhere return_id is not null\ngroup by return_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:11:32.493886Z", "completed_at": "2026-07-18T16:11:32.504755Z"}, {"name": "execute", "started_at": "2026-07-18T16:11:32.508584Z", "completed_at": "2026-07-18T16:11:32.508599Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.020558834075927734, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_returns_analysis", "compiled": true, "compiled_code": "\n\nwith product_sales as (\n    select\n        product_id,\n        sum(line_total) as total_sales,\n        count(distinct order_id) as total_orders_with_product\n    from softcart_db.marts.fct_orders\n    group by product_id\n),\n\nproduct_returns as (\n    select\n        oi.product_id,\n        count(distinct r.return_id) as total_returns,\n        sum(r.refund_amount) as total_refunded\n    from softcart_db.staging.stg_returns r\n    left join softcart_db.staging.stg_order_items oi\n        on r.order_id = oi.order_id\n    group by oi.product_id\n)\n\nselect\n    s.product_id,\n    p.product_name,\n    s.total_sales,\n    s.total_orders_with_product,\n    coalesce(r.total_returns, 0) as total_returns,\n    coalesce(r.total_refunded, 0) as total_refunded,\n    s.total_sales - coalesce(r.total_refunded, 0) as net_revenue,\n    round(\n        coalesce(r.total_returns, 0) / nullif(s.total_orders_with_product, 0) * 100,\n        2\n    ) as return_rate_pct\nfrom product_sales s\nleft join product_returns r\n    on s.product_id = r.product_id\nleft join softcart_db.staging.stg_products p\n    on s.product_id = p.product_id\norder by return_rate_pct desc", "relation_name": "softcart_db.marts.fct_returns_analysis", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:11:32.491665Z", "completed_at": "2026-07-18T16:11:32.507283Z"}, {"name": "execute", "started_at": "2026-07-18T16:11:32.509579Z", "completed_at": "2026-07-18T16:11:32.509591Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.02211761474609375, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_customer_rfm", "compiled": true, "compiled_code": "\n\nwith customer_orders as (\n    select\n        customer_id,\n        max(order_date) as last_order_date,\n        count(distinct order_id) as frequency,\n        sum(order_total) as monetary\n    from softcart_db.marts.fct_orders\n    group by customer_id\n),\n\nrfm_scores as (\n    select\n        customer_id,\n        last_order_date,\n        frequency,\n        monetary,\n        datediff('day', last_order_date, current_date()) as recency_days,\n\n        -- Score 1-5 for each dimension using quintiles (5 = best)\n        ntile(5) over (order by datediff('day', last_order_date, current_date()) desc) as recency_score,\n        ntile(5) over (order by frequency asc) as frequency_score,\n        ntile(5) over (order by monetary asc) as monetary_score\n    from customer_orders\n)\n\nselect\n    customer_id,\n    last_order_date,\n    recency_days,\n    frequency,\n    monetary,\n    recency_score,\n    frequency_score,\n    monetary_score,\n    (recency_score + frequency_score + monetary_score) as rfm_total_score,\n    case\n        when recency_score >= 4 and frequency_score >= 4 and monetary_score >= 4 then 'Champions'\n        when recency_score >= 3 and frequency_score >= 3 then 'Loyal Customers'\n        when recency_score >= 4 and frequency_score <= 2 then 'New Customers'\n        when recency_score <= 2 and frequency_score >= 3 then 'At Risk'\n        when recency_score <= 2 and frequency_score <= 2 and monetary_score <= 2 then 'Lost'\n        else 'Needs Attention'\n    end as customer_segment\nfrom rfm_scores\norder by rfm_total_score desc", "relation_name": "softcart_db.marts.fct_customer_rfm", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:11:32.499678Z", "completed_at": "2026-07-18T16:11:32.512176Z"}, {"name": "execute", "started_at": "2026-07-18T16:11:32.525821Z", "completed_at": "2026-07-18T16:11:32.525836Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.03486800193786621, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null