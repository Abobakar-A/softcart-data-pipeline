age": null, "failures": null, "unique_id": "model.softcart.fct_returns_analysis", "compiled": true, "compiled_code": "\n\nwith product_sales as (\n    select\n        product_id,\n        sum(line_total) as total_sales,\n        count(distinct order_id) as total_orders_with_product\n    from softcart_db.marts.fct_orders\n    group by product_id\n),\n\nproduct_returns as (\n    select\n        oi.product_id,\n        count(distinct r.return_id) as total_returns,\n        sum(r.refund_amount) as total_refunded\n    from softcart_db.staging.stg_returns r\n    left join softcart_db.staging.stg_order_items oi\n        on r.order_id = oi.order_id\n    group by oi.product_id\n)\n\nselect\n    s.product_id,\n    p.product_name,\n    s.total_sales,\n    s.total_orders_with_product,\n    coalesce(r.total_returns, 0) as total_returns,\n    coalesce(r.total_refunded, 0) as total_refunded,\n    s.total_sales - coalesce(r.total_refunded, 0) as net_revenue,\n    round(\n        coalesce(r.total_returns, 0) / nullif(s.total_orders_with_product, 0) * 100,\n        2\n    ) as return_rate_pct\nfrom product_sales s\nleft join product_returns r\n    on s.product_id = r.product_id\nleft join softcart_db.staging.stg_products p\n    on s.product_id = p.product_id\norder by return_rate_pct desc", "relation_name": "softcart_db.marts.fct_returns_analysis", "batch_results": null, "overload_results": null}], "elapsed_time": 5.429593801498413, "args": {"project_dir": ".", "sqlparse": {"MAX_GROUPING_DEPTH": null, "MAX_GROUPING_TOKENS": null}, "favor_state": false, "show_all_deprecations": false, "support_custom_ref_kwargs": false, "latest_version_pointer_enabled_by_default": false, "require_source_and_semantic_model_names_without_spaces": false, "populate_cache": true, "enable_grouped_warn_error_parser_logs": false, "require_generic_test_arguments_property": true, "invocation_command": "dbt docs generate --project-dir . --profiles-dir /home/runner/.dbt", "validate_macro_args": true, "require_sql