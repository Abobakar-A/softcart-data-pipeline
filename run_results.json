": "model.softcart.fct_returns", "compiled": true, "compiled_code": "\n\nselect\n    r.return_id,\n    r.order_id,\n    o.customer_id,\n    oi.product_id,\n    r.return_date,\n    r.reason,\n    r.status,\n    r.refund_amount\nfrom softcart_db.staging.stg_returns r\nleft join softcart_db.staging.stg_orders o\n    on r.order_id = o.order_id\nleft join softcart_db.staging.stg_order_items oi\n    on r.order_id = oi.order_id\nqualify row_number() over (partition by r.return_id order by oi.product_id) = 1", "relation_name": "softcart_db.marts.fct_returns", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T10:15:42.476164Z", "completed_at": "2026-07-18T10:15:42.487576Z"}, {"name": "execute", "started_at": "2026-07-18T10:15:42.489717Z", "completed_at": "2026-07-18T10:15:42.489724Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.019320249557495117, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.accepted_values_stg_returns_status__requested__approved__rejected__refunded.3d8a39bad8", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        status as value_field,\n        count(*) as n_records\n\n    from softcart_db.staging.stg_returns\n    group by status\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'requested','approved','rejected','refunded'\n)\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T10:15:42.493085Z", "completed_at": "2026-07-18T10:15:42.509280Z"}, {"name": "execute", "started_at": "2026-07-18T10:15:42.515585Z", "completed_at": "2026-07-18T10:15:42.515596Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.02865314483642578, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_stg_returns_order_id.d16a4eb67e", "compile