s, 0) / nullif(s.total_orders_with_product, 0) * 100,\n        2\n    ) as return_rate_pct\nfrom product_sales s\nleft join product_returns r\n    on s.product_id = r.product_id\nleft join softcart_db.staging.stg_products p\n    on s.product_id = p.product_id\norder by return_rate_pct desc", "relation_name": "softcart_db.marts.fct_returns_analysis", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T06:31:39.924389Z", "completed_at": "2026-07-18T06:31:39.933116Z"}, {"name": "execute", "started_at": "2026-07-18T06:31:39.933628Z", "completed_at": "2026-07-18T06:31:39.933636Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.01945042610168457, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_customer_rfm", "compiled": true, "compiled_code": "\n\nwith customer_orders as (\n    select\n        customer_id,\n        max(order_date) as last_order_date,\n        count(distinct order_id) as frequency,\n        sum(order_total) as monetary\n    from softcart_db.marts.fct_orders\n    group by customer_id\n),\n\nrfm_scores as (\n    select\n        customer_id,\n        last_order_date,\n        frequency,\n        monetary,\n        datediff('day', last_order_date, current_date()) as recency_days,\n\n        -- Score 1-5 for each dimension using quintiles (5 = best)\n        ntile(5) over (order by datediff('day', last_order_date, current_date()) desc) as recency_score,\n        ntile(5) over (order by frequency asc) as frequency_score,\n        ntile(5) over (order by monetary asc) as monetary_score\n    from customer_orders\n)\n\nselect\n    customer_id,\n    last_order_date,\n    recency_days,\n    frequency,\n    monetary,\n    recency_score,\n    frequency_score,\n    monetary_score,\n    (recency_score + frequency_score + monetary_score) as rfm_total_score,\n    case\n        when recency_score >= 4 and frequency_score >= 4 and monetary_score >= 4 then 'Champions'\n        when recency_score >= 3 and frequency_score >= 3 then 'Loyal Customers'\n        when recency_score >= 4 and frequency_score <= 2 then 'New Customers'\n        when recency_score <= 2 and frequency_score >= 3 then 'At Risk'\n        when recency_score <= 2 and frequency_score <= 2 and monetary_score <= 2 then 'Lost'\n        else 'Needs Attention'\n    end as customer_segment\nfrom rfm_scores\norder by rfm_total_score desc", "relation_name": "softcart_db.marts.fct_customer_rfm", "batch_results": null, "overload_results": null}], "elapsed_time": 5.599261045455933, "args": {"use_v2_parser": false, "support_custom_ref_kwargs": false, "use_catalogs_v2": false, "require_batched_execution_for_custom_microbatch_strategy": true, "require_sql_header_in_test_configs": false, "log_format": "default", "partial_parse_file_diff": true, "project_dir": ".", "require_generic_test_arguments_property": true, "exclude": [], "log_format_file": "debug", "latest_version_pointer_enabled_by_default": false, "show_all_deprecations": false, "write_json": true, "send_anonymous_usage_stats": true, "strict_mode": false, "defer": false, "empty_catalog": false, "vars": {}, "require_resource_names_without_spaces": true, "compile": true, "require_corrected_analysis_fqns": false, "require_nested_cumulative_type_params": true, "validate_macro_args": true, "static_parser": true, "enable_grouped_warn_error_parser_logs": false, "warn_error_options": {"error": [], "warn": [], "silence": []}, "require_all_warnings_handled_by_warn_error": true, "macro_debugging": false, "require_ref_searches_node_package_before_root": false, "require_source_and_semantic_model_names_without_spaces": false, "skip_nodes_if_on_run_start_fails": true, "quiet": false, "populate_cache": true, "log_file_max_bytes": 10485760, "state_modified_compare_more_unrendered_values": true, "maximum_seed_size_mib": 1, "require_explicit_package_overrides_for_builtin_materializations": true, "invocation_command": "d