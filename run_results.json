ns\nwhere return_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-17T11:59:01.289330Z", "completed_at": "2026-07-17T11:59:01.300770Z"}, {"name": "execute", "started_at": "2026-07-17T11:59:01.306814Z", "completed_at": "2026-07-17T11:59:01.306820Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.019817829132080078, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.relationships_stg_returns_order_id__order_id__ref_stg_orders_.c3a878ae38", "compiled": true, "compiled_code": "\n    \n    \n\nwith child as (\n    select order_id as from_field\n    from softcart_db.staging.stg_returns\n    where order_id is not null\n),\n\nparent as (\n    select order_id as to_field\n    from softcart_db.staging.stg_orders\n)\n\nselect\n    from_field\n\nfrom child\nleft join parent\n    on child.from_field = parent.to_field\n\nwhere parent.to_field is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-17T11:59:01.301090Z", "completed_at": "2026-07-17T11:59:01.308126Z"}, {"name": "execute", "started_at": "2026-07-17T11:59:01.315138Z", "completed_at": "2026-07-17T11:59:01.315146Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.020358562469482422, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.unique_stg_products_product_id.7d950a1467", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    product_id as unique_field,\n    count(*) as n_records\n\nfrom softcart_db.staging.stg_products\nwhere product_id is not null\ngroup by product_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-17T11:59:01.308871Z", "completed_at": "2026-07-17T11:59:01.316419Z"}, {"name": "execute", "started_at": "2026-07-17T11:59:01.317454Z", "completed_at": "2026-07-17T11:59:01.317477Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.01154780387878418, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.unique_stg_returns_return_id.c2232dee8a", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    return_id as unique_field,\n    count(*) as n_records\n\nfrom softcart_db.staging.stg_returns\nwhere return_id is not null\ngroup by return_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-17T11:59:01.313565Z", "completed_at": "2026-07-17T11:59:01.316811Z"}, {"name": "execute", "started_at": "2026-07-17T11:59:01.317999Z", "completed_at": "2026-07-17T11:59:01.318007Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.011701345443725586, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_customer_rfm", "compiled": true, "compiled_code": "\n\nwith customer_orders as (\n    select\n        customer_id,\n        max(order_date) as last_order_date,\n        count(distinct order_id) as frequency,\n        sum(order_total) as monetary\n    from softcart_db.marts.fct_orders\n    group by customer_id\n),\n\nrfm_scores as (\n    select\n        customer_id,\n        last_order_date,\n        frequency,\n        monetary,\n        datediff('day', last_order_date, current_date()) as recency_days,\n\n        -- Score 1-5 for each dimension using quintiles (5 = best)\n        ntile(5) over (order by datediff('day', last_order_date, current_date()) desc) as recency_score,\n        ntile(5) over (order by frequency asc) as frequency_score,\n        ntile(5) over (order by monetary asc) as monetary_score\n    from customer_orders\n)\n\nselect\n    customer_id,\n    last_order_date,\n    recency_days,\n    frequency,\n    monetary,\n    recency_score,\n    frequency_score,\n    monetary_score,\n    (recency_score + frequency_score + monetary_score) as rfm_total_score,\n    case\n        when recency_score >= 4 and frequency_score >= 4 and monetary_score >= 4 then 'Champions'\n        when recency_score >= 3 and frequency_score >= 3 then 'Loyal Customers'\n        when recency_score >= 4 and frequency_score <= 2 then 'New Customers'\n        when recency_score <= 2 and frequency_score >= 3 then 'At Risk'\n        when recency_score <= 2 and frequency_score <= 2 and monetary_score <= 2 then 'Lost'\n        else 'Needs Attention'\n    end as customer_segment\nfrom rfm_scores\norder by rfm_total_score desc", "relation_name": "softcart_db.marts.fct_customer_rfm", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-17T11:59:01.318541Z", "completed_at": "2026-07-17T11:59:01.320736Z"}, {"name": "execute", "started_at": "2026-07-17T11:59:01.321039Z", "completed_at": "2026-07-17T11:59:01.321044Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.005400896072387695, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_returns_analysis", "compiled": true, "compiled_code": "\n\nwith product_sales as (\n    select\n        product_id,\n        sum(line_total) as total_sales,\n        count(distinct order_id) as total_orders_with_product\n    from softcart_db.marts.fct_orders\n    group by product_id\n),\n\nproduct_returns as (\n    select\n        oi.product_id,\n        count(distinct r.return_id) as total_returns,\n        sum(r.refund_amount) as total_refunded\n    from softcart_db.staging.stg_returns r\n    left join softcart_db.staging.stg_order_items oi\n        on r.order_id = oi.order_id\n    group by oi.product_id\n)\n\nselect\n    s.product_id,\n    p.product_name,\n    s.total_sales,\n    s.total_orders_with_product,\n    coalesce(r.total_returns, 0) as total_returns,\n    coalesce(r.total_refunded, 0) as total_refunded,\n    s.total_sales - coalesce(r.total_refunded, 0) as net_revenue,\n    round(\n        coalesce(r.total_returns, 0) / nullif(s.total_orders_with_product, 0) * 100,\n        2\n    ) as return_rate_pct\nfrom product_sales s\nleft join product_returns r\n    on s.product_id = r.product_id\nleft join softcart_db.staging.stg_products p\n    on s.product_id = p.product_id\norder by return_rate_pct desc", "relation_name": "softcart_db.marts.fct_returns_analysis", "batch_results": null, "overload_results": null}], "elapsed_time": 4.286657094955444, "args": {"latest_version_pointer_enabled_by_default": false, "state_modified_compare_vars": false, "enable_grouped_warn_error_parser_logs": false, "log_level": "info", "compile": true, "partial_parse": true, "which": "generate", "vars": {}, "log_path": "logs", "v2_parser": "dbt-core-experimental-parser parse", "indirect_selection": "eager", "require_unique_project_resource_names": false, "select": [], "use_catalogs_v2": false, "require_valid_schema_from_generate_schema_name": false, "use_colors_file": true, "require_resource_names_without_spaces": true, "show_resource_report": false, "require_yaml_configuration_for_mf_time_spines": true, "require_corrected_analysis_fqns": false, "version_check": true, "project_dir": ".", "maximum_seed_size_mib": 1, "populate_cache": true, "introspect": true, "use_colors": true, "require_explicit_package_overrides_for_builtin_materializations": true, "empty_catalog": false, "require_all_warnings_handled_by_warn_error": true, "static": false, "cache_selected_only": false, "printer_width": 80, "log_level_file": "debug", "support_custom_ref_kwargs": false, "show_all_deprecations": false, "log_format_file": "debug", "use_fast_test_edges": false, "profiles_dir": "/home/runner/.dbt", "exclude": [], "require_ref_searches_node_package_before_root": false, "require_sql_header_in_test_configs": false, "use_v2_parser": false, "favor_state": false, "