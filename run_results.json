: true, "compiled_code": "-- This test fails if any return's refund_amount exceeds the original order's order_total.\n-- A refund larger than the order itself is a data quality issue that should never happen.\n\nselect\n    r.return_id,\n    r.order_id,\n    r.refund_amount,\n    o.order_total\nfrom softcart_db.staging.stg_returns r\nleft join softcart_db.staging.stg_orders o\n    on r.order_id = o.order_id\nwhere r.refund_amount > o.order_total", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:14:51.673472Z", "completed_at": "2026-07-18T16:14:51.690769Z"}, {"name": "execute", "started_at": "2026-07-18T16:14:51.693160Z", "completed_at": "2026-07-18T16:14:51.693170Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.03240060806274414, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_stg_returns_order_id.d16a4eb67e", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect order_id\nfrom softcart_db.staging.stg_returns\nwhere order_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:14:51.681335Z", "completed_at": "2026-07-18T16:14:51.692066Z"}, {"name": "execute", "started_at": "2026-07-18T16:14:51.694415Z", "completed_at": "2026-07-18T16:14:51.694423Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.03267073631286621, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_stg_returns_return_id.8e8e7cd8be", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect return_id\nfrom softcart_db.staging.stg_returns\nwhere return_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:14:51.697353Z", "completed_at": "2026-07-18T16:14:51.724450Z"}, {"name": "execute", "started_at": "2026-07-18T16:14:51.725372Z", "completed_at": "2026-07-18T16:14:51.725385Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.03296399116516113, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.relationships_stg_returns_order_id__order_id__ref_stg_orders_.c3a878ae38", "compiled": true, "compiled_code": "\n    \n    \n\nwith child as (\n    select order_id as from_field\n    from softcart_db.staging.stg_returns\n    where order_id is not null\n),\n\nparent as (\n    select order_id as to_field\n    from softcart_db.staging.stg_orders\n)\n\nselect\n    from_field\n\nfrom child\nleft join parent\n    on child.from_field = parent.to_field\n\nwhere parent.to_field is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:14:51.719271Z", "completed_at": "2026-07-18T16:14:51.726688Z"}, {"name": "execute", "started_at": "2026-07-18T16:14:51.727894Z", "completed_at": "2026-07-18T16:14:51.727902Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.025535106658935547, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_customer_rfm", "compiled": true, "compiled_code": "\n\nwith customer_orders as (\n    select\n        customer_id,\n        max(order_date) as last_order_date,\n        count(distinct order_id) as frequency,\n        sum(order_total) as monetary\n    from softcart_db.marts.fct_orders\n    group by customer_id\n),\n\nrfm_scores as (\n    select\n        customer_id,\n        last_order_date,\n        frequency,\n        monetary,\n        datediff('day', last_order_date, current_date()) as recency_days,\n\n        -- Score 1-5 for each dimension using quintiles (5 = best)\n        ntile(5) over (order by datediff('day', last_order_date, current_date()) desc) as recency_score,\n        ntile(5) over (order by frequency asc) as frequency_score,\n        ntile(5) over (order by monetary asc) as monetary_score\n    from customer_orders\n)\n\nselect\n    customer_id,\n    last_order_date,\n    recency_days,\n    frequency,\n    monetary,\n    recency_score,\n    frequency_score,\n    monetary_score,\n    (recency_score + frequency_score + monetary_score) as rfm_total_score,\n    case\n        when recency_score >= 4 and frequency_score >= 4 and monetary_score >= 4 then 'Champions'\n        when recency_score >= 3 and frequency_score >= 3 then 'Loyal Customers'\n        when recency_score >= 4 and frequency_score <= 2 then 'New Customers'\n        when recency_score <= 2 and frequency_score >= 3 then 'At Risk'\n        when recency_score <= 2 and frequency_score <= 2 and monetary_score <= 2 then 'Lost'\n        else 'Needs Attention'\n    end as customer_segment\nfrom rfm_scores\norder by rfm_total_score desc", "relation_name": "softcart_db.marts.fct_customer_rfm", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:14:51.721584Z", "completed_at": "2026-07-18T16:14:51.728612Z"}, {"name": "execute", "started_at": "2026-07-18T16:14:51.730276Z", "completed_at": "2026-07-18T16:14:51.730287Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.019870519638061523, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.softcart.fct_returns_analysis", "compiled": true, "compiled_code": "\n\nwith product_sales as (\n    select\n        product_id,\n        sum(line_total) as total_sales,\n        count(distinct order_id) as total_orders_with_product\n    from softcart_db.marts.fct_orders\n    group by product_id\n),\n\nproduct_returns as (\n    select\n        oi.product_id,\n        count(distinct r.return_id) as total_returns,\n        sum(r.refund_amount) as total_refunded\n    from softcart_db.staging.stg_returns r\n    left join softcart_db.staging.stg_order_items oi\n        on r.order_id = oi.order_id\n    group by oi.product_id\n)\n\nselect\n    s.product_id,\n    p.product_name,\n    s.total_sales,\n    s.total_orders_with_product,\n    coalesce(r.total_returns, 0) as total_returns,\n    coalesce(r.total_refunded, 0) as total_refunded,\n    s.total_sales - coalesce(r.total_refunded, 0) as net_revenue,\n    round(\n        coalesce(r.total_returns, 0) / nullif(s.total_orders_with_product, 0) * 100,\n        2\n    ) as return_rate_pct\nfrom product_sales s\nleft join product_returns r\n    on s.product_id = r.product_id\nleft join softcart_db.staging.stg_products p\n    on s.product_id = p.product_id\norder by return_rate_pct desc", "relation_name": "softcart_db.marts.fct_returns_analysis", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:14:51.711695Z", "completed_at": "2026-07-18T16:14:51.731111Z"}, {"name": "execute", "started_at": "2026-07-18T16:14:51.740821Z", "completed_at": "2026-07-18T16:14:51.740832Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.04466104507446289, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.unique_stg_returns_return_id.c2232dee8a", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    return_id as unique_field,\n    count(*) as n_records\n\nfrom softcart_db.staging.stg_returns\nwhere return_id is not null\ngroup by return_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T16:14:51.731591Z", "completed_at": "2026-07-18T16:14:51.756412Z"}, {"name": "execute", "started_at": "2026-07-18T16:14:51.769558Z", "completed_at": "2026-07-18T16:14:51.769570Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.0424501895904541, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_fct_r