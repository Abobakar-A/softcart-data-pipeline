rns, 0) / nullif(s.total_orders_with_product, 0) * 100,\n        2\n    ) as return_rate_pct\nfrom product_sales s\nleft join product_returns r\n    on s.product_id = r.product_id\nleft join softcart_db.staging.stg_products p\n    on s.product_id = p.product_id\norder by return_rate_pct desc", "relation_name": "softcart_db.marts.fct_returns_analysis", "batch_results": null, "overload_results": null}], "elapsed_time": 5.187676668167114, "args": {"print": true, "skip_nodes_if_on_run_start_fails": true, "log_file_max_bytes": 10485760, "project_dir": ".", "introspect": true, "log_format_file": "debug", "exclude": [], "latest_version_pointer_enabled_by_default": false, "use_colors_file": true, "upload_to_artifacts_ingest_api": false, "require_sql_header_in_test_configs": false, "which": "generate", "populate_cache": true, "vars": {}, "require_valid_schema_from_generate_schema_name": false, "require_corrected_analysis_fqns": false, "use_catalogs_v2": false, "defer": false, "write_json": true, "require_generic_test_arguments_property": true, "hints_enabled": true, "require_resource_names_without_spaces": true, "warn_error_options": {"error": [], "warn": [], "silence": []}, "state_modified_compare_more_unrendered_values": true, "validate_macro_args": true, "indirect_selection": "eager", "v2_parser": "dbt-core-experimental-parser parse", "static": false, "require_explicit_package_overrides_for_builtin_materializations": true, "profiles_dir": "/home/runner/.dbt", "version_check": true, "require_source_and_semantic_model_names_without_spaces": false, "partial_parse_file_diff": true, "require_unique_project_resource_names": false, "cache_selected_only": false, "favor_state": false, "state_modified_compare_vars": false, "send_anonymous_usage_stats": true, "source_freshness_run_project_hooks": true, "log_path": "logs", "quiet": false, "printer_width": 80, "static_parser": true, "strict_mode": false, "require_ref_searches_node_package_before_root": false, "use_v2_parser": false, "