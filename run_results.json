ique_id": "test.softcart.accepted_values_stg_returns_status__requested__approved__rejected__refunded.3d8a39bad8", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        status as value_field,\n        count(*) as n_records\n\n    from softcart_db.staging.stg_returns\n    group by status\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'requested','approved','rejected','refunded'\n)\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T06:31:39.874425Z", "completed_at": "2026-07-18T06:31:39.893993Z"}, {"name": "execute", "started_at": "2026-07-18T06:31:39.895232Z", "completed_at": "2026-07-18T06:31:39.895243Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.0251004695892334, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.assert_refund_not_exceeding_order_total", "compiled": true, "compiled_code": "-- This test fails if any return's refund_amount exceeds the original order's order_total.\n-- A refund larger than the order itself is a data quality issue that should never happen.\n\nselect\n    r.return_id,\n    r.order_id,\n    r.refund_amount,\n    o.order_total\nfrom softcart_db.staging.stg_returns r\nleft join softcart_db.staging.stg_orders o\n    on r.order_id = o.order_id\nwhere r.refund_amount > o.order_total", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T06:31:39.885202Z", "completed_at": "2026-07-18T06:31:39.896067Z"}, {"name": "execute", "started_at": "2026-07-18T06:31:39.909566Z", "completed_at": "2026-07-18T06:31:39.909576Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.03687572479248047, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_stg_returns_return_id.8e8e7cd8be", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect return_id\nfrom softcart_db.staging.stg_returns\nwhere return_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T06:31:39.878062Z", "completed_at": "2026-07-18T06:31:39.906891Z"}, {"name": "execute", "started_at": "2026-07-18T06:31:39.910473Z", "completed_at": "2026-07-18T06:31:39.910482Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.03917098045349121, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.not_null_stg_returns_order_id.d16a4eb67e", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect order_id\nfrom softcart_db.staging.stg_returns\nwhere order_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T06:31:39.896608Z", "completed_at": "2026-07-18T06:31:39.912607Z"}, {"name": "execute", "started_at": "2026-07-18T06:31:39.914913Z", "completed_at": "2026-07-18T06:31:39.914921Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.021616458892822266, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.softcart.relationships_stg_returns_order_id__order_id__ref_stg_orders_.c3a878ae38", "compiled": true, "compiled_code": "\n    \n    \n\nwith child as (\n    select order_id as from_field\n    from softcart_db.staging.stg_returns\n    where order_id is not null\n),\n\nparent as (\n    select order_id as to_field\n    from softcart_db.staging.stg_orders\n)\n\nselect\n    from_field\n\nfrom child\nleft join parent\n    on child.from_field = parent.to_field\n\nwhere parent.to_field is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-18T06:31:39.916312Z", "completed_at": "2026-07-18T06:31:39.9