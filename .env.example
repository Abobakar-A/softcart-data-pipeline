# Snowflake connection (used in airflow/dbt_profile/profiles.yml — not committed)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_DATABASE=softcart_db
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=dbt_dev

# Azure Data Lake connection (used in Airflow connection: azure_data_lake_default)
AZURE_STORAGE_CONNECTION_STRING=

# Slack alerting (used in Airflow Variable: slack_webhook_url)
SLACK_WEBHOOK_URL=

# Airflow
AIRFLOW_UID=1000
